# ── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ──────────────────────────────────────────────
# Uses PostGIS image from docker-compose
DATABASE_URL="postgresql://postgres:password@localhost:5432/streetbite?schema=public"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Clerk Auth ────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SECRET="whsec_..."

# ── Stripe ────────────────────────────────────────────────
# Get from https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Cloudinary ────────────────────────────────────────────
# Get from https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ── Resend (Email) ────────────────────────────────────────
# Get from https://resend.com → API Keys
RESEND_API_KEY="re_..."

# ── Twilio (SMS) ──────────────────────────────────────────
# Get from https://console.twilio.com
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1..."

# ── Google Maps ───────────────────────────────────────────
# Get from https://console.cloud.google.com → APIs & Services
GOOGLE_MAPS_API_KEY="AIza..."

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ── Sentry (optional) ─────────────────────────────────────
SENTRY_DSN=""
