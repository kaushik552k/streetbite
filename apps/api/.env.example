# ──────────────────────────────────────────────
# StreetBite API — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Server ─────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── Database ───────────────────────────────────
# PostgreSQL connection string (with PostGIS extension)
# Local Docker: postgresql://postgres:postgres@localhost:5432/streetbite
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/streetbite

# ── Redis ──────────────────────────────────────
# Local Docker: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ── Clerk (Authentication) ─────────────────────
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Stripe (Payments) ──────────────────────────
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── CORS ───────────────────────────────────────
# In production: restrict to your actual frontend URLs
# e.g. https://owner.streetbite.com,https://admin.streetbite.com
# In development: set to 'true' to allow all origins
CORS_ORIGINS=true

# ── Dev Bypass Token (LOCAL DEVELOPMENT ONLY) ──
# Allows testing all 3 frontends without real Clerk JWT.
# THREE token variants are supported:
#   dev_bypass        → authenticates as CUSTOMER (mobile app)
#   dev_bypass_owner  → authenticates as OWNER    (owner portal)
#   dev_bypass_admin  → authenticates as ADMIN    (admin portal)
#
# ⚠️  REMOVE THIS ENTIRELY BEFORE DEPLOYING TO PRODUCTION ⚠️
DEV_BYPASS_TOKEN=dev_bypass
