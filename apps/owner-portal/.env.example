# ──────────────────────────────────────────────
# StreetBite Owner Portal — Environment Variables
# Copy this file to .env and fill in your values
# All variables MUST be prefixed with VITE_ to be exposed to the browser
# ──────────────────────────────────────────────

# ── Clerk (Authentication) ─────────────────────
# Get from: https://dashboard.clerk.com → API Keys → Publishable Key
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── API ────────────────────────────────────────
# URL of the running Fastify API server
# Local development: http://localhost:4000
# Production: https://api.streetbite.com
VITE_API_URL=http://localhost:4000

# ── Dev Mode ───────────────────────────────────
# Controls whether real Clerk authentication is required.
#
# true  → Bypass Clerk sign-in entirely. Dashboard is accessible without a session.
#         All API requests use VITE_DEV_TOKEN (requires DEV_BYPASS_TOKEN set in
#         apps/api/.env). Use this for fast UI development.
#
# false → Real Clerk authentication required. User must sign in before accessing
#         the dashboard. API requests use the real Clerk JWT from the session.
#         Use this to test the auth flow end-to-end, or in production.
#
VITE_DEV_MODE=false

# ── Dev Token ──────────────────────────────────
# The bypass token to use when VITE_DEV_MODE=true.
# Must match DEV_BYPASS_TOKEN set in apps/api/.env + the '_owner' suffix.
# This authenticates all requests as the first OWNER-role user in the database.
# ⚠️  REMOVE THIS ENTIRELY BEFORE DEPLOYING TO PRODUCTION ⚠️
VITE_DEV_TOKEN=
