# ──────────────────────────────────────────────
# StreetBite Mobile App — Environment Variables
# Copy this file to .env and fill in your values
# All variables MUST be prefixed with EXPO_PUBLIC_ to be available in the app
# ──────────────────────────────────────────────

# ── Clerk (Authentication) ─────────────────────
# Get from: https://dashboard.clerk.com → API Keys → Publishable Key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── API ────────────────────────────────────────
# URL of the running Fastify API server
# Local development: http://localhost:4000
# Production: https://api.streetbite.com
EXPO_PUBLIC_API_URL=http://localhost:4000

# ── Dev Mode ───────────────────────────────────
# Controls whether real Clerk authentication is required.
#
# true  → Bypass Clerk sign-in entirely. App boots directly to tabs.
#         All API requests use the 'dev_bypass' token (requires DEV_BYPASS_TOKEN
#         set in apps/api/.env). Use this for fast UI development.
#
# false → Real Clerk authentication required. User must sign in before
#         accessing tabs. API requests use the real Clerk JWT.
#         Use this to test the auth flow end-to-end.
#
EXPO_PUBLIC_DEV_MODE=false

# ── Expo Offline ───────────────────────────────
# Set to '1' to skip Expo version checks (fixes Node.js fetch bug on Windows)
EXPO_OFFLINE=1
